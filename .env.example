# Copy to .env (git-ignored). Secrets only.

# Your LLM API key (used by Foreman's PM Brain / Reviewer — NOT by claude/codex themselves).
FOREMAN_LLM_API_KEY=sk-your-key-here

# Web Push (Web Push uses VAPID). Generate with: python scripts/gen_vapid.py
# Put the PRIVATE key here; the PUBLIC key goes in config.yaml (push.vapid_public_key).
FOREMAN_VAPID_PRIVATE_KEY=

# Auth token for the phone. Leave blank to auto-generate on first run (printed to console once).
FOREMAN_AUTH_TOKEN=

# Optional at-rest encryption key for definition bodies. Generate: python scripts/gen_definition_key.py
# Empty = recipe bodies stay plaintext in foreman.db (the default).
FOREMAN_DEFINITION_KEY=

# Notification channels (DESIGN §776, T6.3). Each stays disabled until its secret is set AND the
# matching notify.<channel>.enabled flag is true in config.yaml. Leave blank to keep disabled.
FOREMAN_FEISHU_WEBHOOK=
FOREMAN_TELEGRAM_BOT_TOKEN=
FOREMAN_BARK_KEY=
FOREMAN_SMTP_PASSWORD=
